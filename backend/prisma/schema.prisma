// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(TENANT)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedProperties  Property[]      @relation("PropertyOwner")
  tenantContracts  Contract[]      @relation("ContractTenant")
  maintenanceRequests MaintenanceRequest[]
  payments         Payment[]
  notifications    Notification[]

  @@map("users")
}

enum Role {
  ADMIN
  OWNER
  AGENT
  TENANT
}

model Property {
  id          String        @id @default(uuid())
  title       String
  description String?
  type        PropertyType
  status      PropertyStatus @default(AVAILABLE)
  price       Float
  area        Float
  bedrooms    Int?
  bathrooms   Int?
  floor       Int?
  address     String
  city        String
  district    String?
  lat         Float?
  lng         Float?
  images      String[]
  amenities   String[]
  ownerId     String
  owner       User          @relation("PropertyOwner", fields: [ownerId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  contracts   Contract[]
  maintenanceRequests MaintenanceRequest[]
  listings    Listing[]

  @@map("properties")
}

enum PropertyType {
  APARTMENT
  VILLA
  OFFICE
  SHOP
  WAREHOUSE
  LAND
  BUILDING
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  SOLD
  UNDER_MAINTENANCE
  RESERVED
}

model Contract {
  id          String         @id @default(uuid())
  type        ContractType
  status      ContractStatus @default(ACTIVE)
  propertyId  String
  property    Property       @relation(fields: [propertyId], references: [id])
  tenantId    String
  tenant      User           @relation("ContractTenant", fields: [tenantId], references: [id])
  startDate   DateTime
  endDate     DateTime
  monthlyRent Float?
  salePrice   Float?
  deposit     Float?
  terms       String?
  documents   String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  payments    Payment[]

  @@map("contracts")
}

enum ContractType {
  RENTAL
  SALE
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  PENDING
}

model MaintenanceRequest {
  id          String            @id @default(uuid())
  title       String
  description String
  category    MaintenanceCategory
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(PENDING)
  propertyId  String
  property    Property          @relation(fields: [propertyId], references: [id])
  requestedBy String
  requester   User              @relation(fields: [requestedBy], references: [id])
  assignedTo  String?
  cost        Float?
  images      String[]
  notes       String?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("maintenance_requests")
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  PAINTING
  CLEANING
  SECURITY
  APPLIANCES
  STRUCTURAL
  OTHER
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

model Listing {
  id          String   @id @default(uuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
  type        ListingType
  title       String
  description String
  price       Float
  isActive    Boolean  @default(true)
  views       Int      @default(0)
  featured    Boolean  @default(false)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("listings")
}

enum ListingType {
  FOR_RENT
  FOR_SALE
}

model Payment {
  id         String        @id @default(uuid())
  contractId String
  contract   Contract      @relation(fields: [contractId], references: [id])
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  amount     Float
  type       PaymentType
  status     PaymentStatus @default(PENDING)
  dueDate    DateTime
  paidAt     DateTime?
  method     String?
  reference  String?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("payments")
}

enum PaymentType {
  RENT
  DEPOSIT
  MAINTENANCE
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}
