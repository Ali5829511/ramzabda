generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("TENANT")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedProperties     Property[]
  tenantContracts     Contract[]
  maintenanceRequests MaintenanceRequest[]
  payments            Payment[]
  notifications       Notification[]

  @@map("users")
}

model Property {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String
  status      String   @default("AVAILABLE")
  price       Float
  area        Float
  bedrooms    Int?
  bathrooms   Int?
  floor       Int?
  address     String
  city        String
  district    String?
  lat         Float?
  lng         Float?
  images      String[]
  amenities   String[]
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contracts           Contract[]
  maintenanceRequests MaintenanceRequest[]
  listings            Listing[]

  @@map("properties")
}

model Contract {
  id          String   @id @default(uuid())
  type        String
  status      String   @default("ACTIVE")
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
  tenantId    String
  tenant      User     @relation(fields: [tenantId], references: [id])
  startDate   DateTime
  endDate     DateTime
  monthlyRent Float?
  salePrice   Float?
  deposit     Float?
  terms       String?
  documents   String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments Payment[]

  @@map("contracts")
}

model MaintenanceRequest {
  id          String    @id @default(uuid())
  title       String
  description String
  category    String
  priority    String    @default("MEDIUM")
  status      String    @default("PENDING")
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  requestedBy String
  requester   User      @relation(fields: [requestedBy], references: [id])
  assignedTo  String?
  cost        Float?
  images      String[]
  notes       String?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("maintenance_requests")
}

model Listing {
  id          String    @id @default(uuid())
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  type        String
  title       String
  description String
  price       Float
  isActive    Boolean   @default(true)
  views       Int       @default(0)
  featured    Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("listings")
}

model Payment {
  id         String    @id @default(uuid())
  contractId String
  contract   Contract  @relation(fields: [contractId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  amount     Float
  type       String
  status     String    @default("PENDING")
  dueDate    DateTime
  paidAt     DateTime?
  method     String?
  reference  String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("payments")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}
