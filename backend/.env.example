# =====================================================
# ملف مثال لمتغيرات البيئة - Environment Variables Example
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# Copy this file to .env and update the values for your environment
# =====================================================

# قاعدة البيانات - Database
DATABASE_URL=postgresql://user:password@localhost:5432/ramzabda

# الواجهة الأمامية - Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:3000

# المنفذ - Server Port
PORT=5000

# بيئة التشغيل - Runtime Environment (development | production | test)
NODE_ENV=development

# مفتاح JWT السري - JWT Secret Key (use a long random string in production)
JWT_SECRET=your-secret-key
